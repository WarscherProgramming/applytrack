# ==============================================================
# ApplyTrack — Environment Variables
#
# Copy this file to .env and fill in real values.
# .env is gitignored and must never be committed.
# ==============================================================

# --- PostgreSQL ----------------------------------------------------
POSTGRES_USER=applytrack
POSTGRES_PASSWORD=changeme
POSTGRES_DB=applytrack
POSTGRES_PORT=5432

# DATABASE_URL uses the Docker Compose service name as host.
# Outside Docker (e.g. local psql), replace 'postgres' with 'localhost'.
DATABASE_URL=postgresql://applytrack:changeme@postgres:5432/applytrack

# --- Backend -------------------------------------------------------

# Generate a strong secret with: openssl rand -hex 32
SECRET_KEY=changeme-replace-with-openssl-rand-hex-32

# development | staging | production
ENVIRONMENT=development

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# JSON array — origins allowed to make cross-origin requests to the API
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# URL prefix applied to every API route
API_V1_PREFIX=/api/v1

# --- Frontend ------------------------------------------------------

# VITE_ prefix is required for Vite to expose the variable to the browser
VITE_API_URL=http://localhost:8000
