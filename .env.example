# ==============================================================
# ApplyTrack - Environment Variables
#
# Copy this file to .env for local Docker development.
# Never commit a real .env file or production secrets.
#
# Production target for Milestone 33A:
# - Frontend: Vercel
# - Backend: Render
# - Database: Render Postgres or Neon
# ==============================================================

# ----------------------------------------------------------------
# Local Docker PostgreSQL
# ----------------------------------------------------------------
# Used by docker-compose.yml for the local postgres service.
# In Render/Neon production, use the managed database's DATABASE_URL instead.
POSTGRES_USER=applytrack
POSTGRES_PASSWORD=changeme
POSTGRES_DB=applytrack
POSTGRES_PORT=5432

# Local Docker value uses the Compose service name as host.
# Local non-Docker tools usually use:
# DATABASE_URL=postgresql://applytrack:changeme@localhost:5432/applytrack
# Production Render/Neon example:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
DATABASE_URL=postgresql://applytrack:changeme@postgres:5432/applytrack

# ----------------------------------------------------------------
# Backend application
# ----------------------------------------------------------------
# Generate a production value with: openssl rand -hex 32
SECRET_KEY=changeme-replace-with-openssl-rand-hex-32

# development | staging | production
ENVIRONMENT=development

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# URL prefix applied to every API route.
API_V1_PREFIX=/api/v1

# Public frontend origin. Used after OAuth redirects.
# Local:
FRONTEND_URL=http://localhost:5173
# Production example:
# FRONTEND_URL=https://your-applytrack-app.vercel.app

# JSON array of browser origins allowed to call the backend.
# Keep localhost for development. In production, include the exact Vercel origin.
# Do not use "*" in production; the backend rejects wildcard CORS when
# ENVIRONMENT=production.
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
# Production example:
# BACKEND_CORS_ORIGINS=["https://your-applytrack-app.vercel.app"]

# Auth token lifetimes.
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ----------------------------------------------------------------
# Frontend / Vercel
# ----------------------------------------------------------------
# Vite exposes only VITE_* variables to browser code.
# Local dev points at the local backend.
# In Vercel production, set this to the Render backend origin.
VITE_API_URL=http://localhost:8000
# Production example:
# VITE_API_URL=https://your-applytrack-api.onrender.com

# ----------------------------------------------------------------
# AI platform
# ----------------------------------------------------------------
# mock runs fully offline. openai activates only when OPENAI_API_KEY is set.
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_MAX_RETRIES=2
AI_REQUEST_TIMEOUT=30.0

# ----------------------------------------------------------------
# Gmail OAuth / Google Calendar OAuth foundation
# ----------------------------------------------------------------
# Leave these empty for local simulation mode.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Gmail OAuth redirect URI.
# Local:
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/gmail/callback
# Production example:
# GOOGLE_REDIRECT_URI=https://your-applytrack-api.onrender.com/api/v1/gmail/callback

# Google Calendar OAuth redirect URI.
# Calendar provider writes are still simulation-mode foundations in this repo,
# but the OAuth URL should use the deployed backend callback when enabled.
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:8000/api/v1/calendar-integration/google/callback
# Production example:
# GOOGLE_CALENDAR_REDIRECT_URI=https://your-applytrack-api.onrender.com/api/v1/calendar-integration/google/callback

# true uses the fake Gmail client. Set false only after Google OAuth is ready.
GMAIL_SIMULATION=true

# ----------------------------------------------------------------
# File storage
# ----------------------------------------------------------------
# Local disk is the only implemented storage backend today.
# On Render, this is ephemeral unless attached to a persistent disk.
# Do not rely on local disk for durable production document storage yet.
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=storage
STORAGE_MAX_UPLOAD_BYTES=10485760
